# =============================================================================
# Tek referans: tüm ortam değişkenleri (backend + frontend build)
# =============================================================================
# Yerel backend: repo kökünde `.env` oluşturup bu dosyayı kopyalayın / birleştirin.
# API sunucusu (ör. PaaS): ortam değişkenleri → aşağıdaki BACKEND anahtarları.
# `npm start` öncesi `npm run build` (tsc) çalıştırılmalı; ayrı build adımı yoksa dist/ boş kalır.
# Statik frontend dağıtımı: CI veya panelde yalnızca VITE_* (Vite build sırasında gömülür).
# Repo kökünden: npm run build:frontend  → çıktı: frontend/dist (sağlayıcıya özel dosya gerekmez).
# =============================================================================

# --- Backend (repo kökü .env veya Render) ---
PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/export_declaration
UPLOAD_DIR=uploads
JSON_BODY_LIMIT=2mb

# Boş: CORS `origin: true`. Üretimde virgülle tam kök URL’ler (path yok, sonda / yok).
# CORS_ORIGIN=https://senin-frontend-ornegi.com,http://localhost:5173

# --- Frontend (CI/build ortamı veya frontend/.env — sadece VITE_*) ---
# API kökü; path EKLEMEYİN (kod /api/... ekler). Sonda /api yazmayın.
# VITE_API_BASE=https://senin-api.onrender.com
# VITE_COMPANY_ID: istemciye gömülür; gizli değildir. Gerçek güvenlik sunucuda oturum + firma yetkisi ile sağlanmalıdır.
# VITE_COMPANY_ID=507f1f77bcf86cd799439011
# VITE_USER_ID=
